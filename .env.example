# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/keep_notion_sync

# Supabase Storage Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=keep-images

# Service URLs (for local development)
API_GATEWAY_URL=http://localhost:8001
ADMIN_INTERFACE_URL=http://localhost:8000
SYNC_SERVICE_URL=http://localhost:8005
KEEP_EXTRACTOR_URL=http://localhost:8003
NOTION_WRITER_URL=http://localhost:8004

# Service Ports
API_GATEWAY_PORT=8001
ADMIN_INTERFACE_PORT=8000
SYNC_SERVICE_PORT=8005
KEEP_EXTRACTOR_PORT=8003
NOTION_WRITER_PORT=8004

# Sync Configuration
# Set to a number (e.g., 5) to limit notes during testing, or leave empty for no limit
SYNC_NOTE_LIMIT=

# Security
SECRET_KEY=your-django-secret-key
ENCRYPTION_KEY=your-base64-encryption-key

# Notifications (optional)
ENABLE_NOTIFICATIONS=false
NOTIFICATION_WEBHOOK_URL=

# Logging
LOG_LEVEL=INFO
